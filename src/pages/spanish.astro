        {cat:"nourriture",es:"el pan",fr:"le pain",ph:"pan",ex:"¿Tienes pan? — Tu as du pain ?"},
        {cat:"nourriture",es:"la carne",fr:"la viande",ph:"karné",ex:"No como carne — Je ne mange pas de viande"},
