        // DIRECTIONS
        {cat:"directions",es:"a la derecha",fr:"à droite",ph:"dérécha",ex:"Gira a la derecha — Tourne à droite"},
        {cat:"directions",es:"a la izquierda",fr:"à gauche",ph:"iskièrda",ex:"Está a la izquierda — C'est à gauche"},
