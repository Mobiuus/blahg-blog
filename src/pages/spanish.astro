          periph:["voy a comer","vas a comer","va a comer","vamos a comer","vais a comer","van a comer"],
          fut:["comeré","comerás","comerá","comeremos","comeréis","comerán"],
          cond:["comería","comerías","comería","comeríamos","comeríais","comerían"],
          ex:{pres:"Como a las dos.",indef:"Comí paella en Valencia.",imperf:"Antes comía más carne.",perf:"Ya he comido, gracias.",periph:"Vamos a comer algo.",fut:"Comeré contigo mañana.",cond:"Comería más si tuviera hambre."}},
        vivir:{type:"régulier -ir",
          pres:["vivo","vives","vive","vivimos","vivís","viven"],
          indef:["viví","viviste","vivió","vivimos","vivisteis","vivieron"],
          imperf:["vivía","vivías","vivía","vivíamos","vivíais","vivían"],
          perf:["he vivido","has vivido","ha vivido","hemos vivido","habéis vivido","han vivido"],
          periph:["voy a vivir","vas a vivir","va a vivir","vamos a vivir","vais a vivir","van a vivir"],
          fut:["viviré","vivirás","vivirá","viviremos","viviréis","vivirán"],
          cond:["viviría","vivirías","viviría","viviríamos","viviríais","vivirían"],
          ex:{pres:"Vivo en París.",indef:"Viví en Madrid dos años.",imperf:"Vivía cerca del mar.",perf:"He vivido aquí diez años.",periph:"Voy a vivir en España.",fut:"Viviré en el extranjero.",cond:"Viviría en el campo si pudiera."}},
        ser:{type:"irrégulier ⚠ même indef. que ir",
          pres:["soy","eres","es","somos","sois","son"],
          indef:["fui","fuiste","fue","fuimos","fuisteis","fueron"],
          imperf:["era","eras","era","éramos","erais","eran"],
          perf:["he sido","has sido","ha sido","hemos sido","habéis sido","han sido"],
          periph:["voy a ser","vas a ser","va a ser","vamos a ser","vais a ser","van a ser"],
          fut:["seré","serás","será","seremos","seréis","serán"],
          cond:["sería","serías","sería","seríamos","seríais","serían"],
          ex:{pres:"Soy francés, soy consultor.",indef:"Fue un gran viaje. (= ir aussi !)",imperf:"Era muy joven entonces.",perf:"Ha sido un placer conocerte.",periph:"Va a ser difícil.",fut:"Será interesante verlo.",cond:"Sería perfecto para mí."}},
        estar:{type:"irrégulier",
          pres:["estoy","estás","está","estamos","estáis","están"],
          indef:["estuve","estuviste","estuvo","estuvimos","estuvisteis","estuvieron"],
          imperf:["estaba","estabas","estaba","estábamos","estabais","estaban"],
          perf:["he estado","has estado","ha estado","hemos estado","habéis estado","han estado"],
          periph:["voy a estar","vas a estar","va a estar","vamos a estar","vais a estar","van a estar"],
          fut:["estaré","estarás","estará","estaremos","estaréis","estarán"],
          cond:["estaría","estarías","estaría","estaríamos","estaríais","estarían"],
          ex:{pres:"Estoy muy bien, gracias.",indef:"Estuve en Barcelona el verano pasado.",imperf:"Estaba muy cansado.",perf:"He estado aquí antes.",periph:"Voy a estar en casa toda la tarde.",fut:"Estaré listo a las ocho.",cond:"Estaría mejor con más tiempo."}},
        tener:{type:"irrégulier",
          pres:["tengo","tienes","tiene","tenemos","tenéis","tienen"],
          indef:["tuve","tuviste","tuvo","tuvimos","tuvisteis","tuvieron"],
          imperf:["tenía","tenías","tenía","teníamos","teníais","tenían"],
          perf:["he tenido","has tenido","ha tenido","hemos tenido","habéis tenido","han tenido"],
          periph:["voy a tener","vas a tener","va a tener","vamos a tener","vais a tener","van a tener"],
          fut:["tendré","tendrás","tendrá","tendremos","tendréis","tendrán"],
          cond:["tendría","tendrías","tendría","tendríamos","tendréis","tendrían"],
          ex:{pres:"Tengo hambre y tengo sed.",indef:"Tuve un problema con el vuelo.",imperf:"Tenía mucho trabajo ese año.",perf:"He tenido mucha suerte.",periph:"Voy a tener que salir pronto.",fut:"Tendré más tiempo la semana que viene.",cond:"Tendría más si pudiera."}},
        ir:{type:"irrégulier ⚠ même indef. que ser",
          pres:["voy","vas","va","vamos","vais","van"],
          indef:["fui","fuiste","fue","fuimos","fuisteis","fueron"],
          imperf:["iba","ibas","iba","íbamos","ibais","iban"],
          perf:["he ido","has ido","ha ido","hemos ido","habéis ido","han ido"],
          periph:["voy a ir","vas a ir","va a ir","vamos a ir","vais a ir","van a ir"],
          fut:["iré","irás","irá","iremos","iréis","irán"],
          cond:["iría","irías","iría","iríamos","iríais","irían"],
          ex:{pres:"Voy al trabajo en metro.",indef:"Fui al cine. (= ser aussi !)",imperf:"Iba todos los días al gimnasio.",perf:"He ido tres veces a México.",periph:"Voy a ir a Madrid este fin de semana.",fut:"Iré si puedo.",cond:"Iría, pero estoy ocupado."}},
        hacer:{type:"irrégulier",
          pres:["hago","haces","hace","hacemos","hacéis","hacen"],
          indef:["hice","hiciste","hizo","hicimos","hicisteis","hicieron"],
          imperf:["hacía","hacías","hacía","hacíamos","hacíais","hacían"],
          perf:["he hecho","has hecho","ha hecho","hemos hecho","habéis hecho","han hecho"],
          periph:["voy a hacer","vas a hacer","va a hacer","vamos a hacer","vais a hacer","van a hacer"],
          fut:["haré","harás","hará","haremos","haréis","harán"],
          cond:["haría","harías","haría","haríamos","haríais","harían"],
          ex:{pres:"¿Qué haces este fin de semana?",indef:"Hice todo lo posible.",imperf:"Hacía frío en diciembre.",perf:"He hecho los deberes.",periph:"Voy a hacer la compra.",fut:"Haré lo que pueda.",cond:"Haría lo mismo en tu lugar."}},
        poder:{type:"irrégulier",
          pres:["puedo","puedes","puede","podemos","podéis","pueden"],
          indef:["pude","pudiste","pudo","pudimos","pudisteis","pudieron"],
          imperf:["podía","podías","podía","podíamos","podíais","podían"],
          perf:["he podido","has podido","ha podido","hemos podido","habéis podido","han podido"],
          periph:["voy a poder","vas a poder","va a poder","vamos a poder","vais a poder","van a poder"],
          fut:["podré","podrás","podrá","podremos","podréis","podrán"],
          cond:["podría","podrías","podría","podríamos","podríais","podrían"],
          ex:{pres:"¿Puedes ayudarme, por favor?",indef:"No pude ir a la reunión.",imperf:"Podía hacerlo solo antes.",perf:"He podido terminar a tiempo.",periph:"Voy a poder venir el jueves.",fut:"Podré hacerlo mañana.",cond:"¿Podrías repetir más despacio?"}},
        querer:{type:"irrégulier",
          pres:["quiero","quieres","quiere","queremos","queréis","quieren"],
          indef:["quise","quisiste","quiso","quisimos","quisisteis","quisieron"],
          imperf:["quería","querías","quería","queríamos","queríais","querían"],
          perf:["he querido","has querido","ha querido","hemos querido","habéis querido","han querido"],
          periph:["voy a querer","vas a querer","va a querer","vamos a querer","vais a querer","van a querer"],
          fut:["querré","querrás","querrá","querremos","querréis","querrán"],
          cond:["querría","querrías","querría","querríamos","querríais","querrían"],
          ex:{pres:"Quiero un café con leche.",indef:"Quise decírtelo antes.",imperf:"De pequeño quería ser piloto.",perf:"Siempre he querido ir a Japón.",periph:"Voy a querer más información.",fut:"¿Querrás venir a la fiesta?",cond:"Querría reservar una mesa para dos."}},
      };

      const VERB_NAMES = Object.keys(VD);
      let cjDeck=[], cIdx=0, cFlipped=false, cScores={easy:0,hard:0,skip:0};
      let currentTense="tous", currentVerb="tous";

      function cjShuffle(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}

      function buildCjDeck(){
        cjDeck=[];
        for(const vName of VERB_NAMES){
          const vd=VD[vName];
          if(currentVerb==="reg" && vd.type.startsWith("irrég")) continue;
          if(currentVerb==="irreg" && !vd.type.startsWith("irrég")) continue;
          for(const t of TENSES){
            if(currentTense!=="tous" && currentTense!==t.id) continue;
            cjDeck.push({verb:vName,type:vd.type,tId:t.id,tLabel:t.label,tFr:t.fr,tUsage:t.usage,tNote:t.note,forms:vd[t.id],ex:vd.ex[t.id]});
          }
        }
        cjDeck=cjShuffle(cjDeck); cIdx=0; cFlipped=false; cScores={easy:0,hard:0,skip:0};
        renderCj();
      }

      function renderCj(){
        const app=document.getElementById('cj-app');
        if(cIdx>=cjDeck.length){
          app.innerHTML='<div class="cj-done"><h3>Deck terminé !</h3><p>Facile : '+cScores.easy+' · Difficile : '+cScores.hard+' · Passé : '+cScores.skip+'</p><div style="display:flex;gap:8px;justify-content:center"><button class="cj-btn" onclick="buildCjDeck()">Recommencer</button></div></div>';
          return;
        }
        const card=cjDeck[cIdx];
        const pct=Math.round(cIdx/cjDeck.length*100);
        const tInfo=currentTense!=="tous" ? TENSES.find(function(t){return t.id===currentTense;}) : null;

        const tensePills='<div class="cj-filter-row"><div class="cj-filter-label">Temps</div><div class="cj-pills">'
          +'<span class="cj-pill all '+(currentTense==="tous"?"active":"")+'" onclick="setCjTense(\'tous\')">Tous</span>'
          +TENSES.map(function(t){return '<span class="cj-pill '+t.usage+' '+(currentTense===t.id?"active":"")+'" onclick="setCjTense(\''+t.id+'\')">'+t.fr+'</span>';}).join('')
          +'</div></div>';

        const verbPills='<div class="cj-filter-row"><div class="cj-filter-label">Verbes</div><div class="cj-pills">'
          +'<span class="cj-pill all '+(currentVerb==="tous"?"active":"")+'" onclick="setCjVerb(\'tous\')">Tous</span>'
          +'<span class="cj-pill reg '+(currentVerb==="reg"?"active":"")+'" onclick="setCjVerb(\'reg\')">Réguliers (-ar/-er/-ir)</span>'
          +'<span class="cj-pill irreg '+(currentVerb==="irreg"?"active":"")+'" onclick="setCjVerb(\'irreg\')">Irréguliers</span>'
          +'</div></div>';

        const infoBox=tInfo
          ?'<div class="cj-info-box '+tInfo.usage+'"><span class="cj-info-strong">'+tInfo.label+'</span> — '+tInfo.note+'</div>'
          :'<div class="cj-info-box mixed"><span class="cj-info-strong" style="color:#3B6D11">oral</span> = passé LatAm / futur proche / passé composé Espagne &nbsp;·&nbsp; <span class="cj-info-strong" style="color:#854F0B">formel/écrit</span> = futur simple &nbsp;·&nbsp; <span class="cj-info-strong" style="color:#185FA5">les deux</span> = présent, imparfait, conditionnel</div>';

        const tableRows=PRONOUNS.map(function(p,i){return '<tr><td class="cj-pron">'+p+'</td><td class="cj-form">'+card.forms[i]+'</td></tr>';}).join('');

        const navOrRate=cFlipped
          ?'<div class="cj-rates"><button class="cj-hard" onclick="cjRate(\'hard\')">Difficile</button><button class="cj-skip" onclick="cjRate(\'skip\')">Passer</button><button class="cj-easy" onclick="cjRate(\'easy\')">Facile</button></div>'
          :'<div class="cj-nav"><button class="cj-btn" onclick="cjPrev()" '+(cIdx===0?"disabled":"")+'>← Préc.</button><button class="cj-btn" onclick="cjFlip()">Voir conjugaison</button><button class="cj-btn" onclick="cjRate(\'skip\')">Suivant →</button></div>';

        app.innerHTML=tensePills+verbPills+infoBox
          +'<div class="cj-stats">'
          +'<div class="cj-stat"><div class="cj-stat-v">'+cjDeck.length+'</div><div class="cj-stat-l">cartes</div></div>'
          +'<div class="cj-stat"><div class="cj-stat-v">'+cIdx+'</div><div class="cj-stat-l">vues</div></div>'
          +'<div class="cj-stat"><div class="cj-stat-v" style="color:#3B6D11">'+cScores.easy+'</div><div class="cj-stat-l">faciles</div></div>'
          +'<div class="cj-stat"><div class="cj-stat-v" style="color:#993C1D">'+cScores.hard+'</div><div class="cj-stat-l">difficiles</div></div>'
          +'</div>'
          +'<div class="cj-pb-bg"><div class="cj-pb-fill" style="width:'+pct+'%"></div></div>'
          +'<div class="cj-card-num">'+(cIdx+1)+' / '+cjDeck.length+'</div>'
          +'<div class="cj-scene" onclick="cjFlip()">'
          +'<div class="cj-3d '+(cFlipped?"flipped":"")+'">'
          +'<div class="cj-face front">'
          +'<div class="cj-verb-big">'+card.verb+'</div>'
          +'<div class="cj-verb-type">'+card.type+'</div>'
          +'<span class="cj-badge '+card.tUsage+'">'+card.tFr+'</span>'
          +'<div class="cj-tense-big">'+card.tLabel+'</div>'
          +'<div class="cj-tense-note">'+card.tNote.split(".")[0]+'.</div>'
          +'<div style="font-size:11px;color:#bbb;margin-top:14px">Cliquer pour voir la conjugaison</div>'
          +'</div>'
          +'<div class="cj-face back">'
          +'<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap">'
          +'<span style="font-size:16px;font-weight:500">'+card.verb+'</span>'
          +'<span class="cj-badge '+card.tUsage+'" style="margin-bottom:0">'+card.tFr+'</span>'
          +'</div>'
          +'<table class="cj-table">'+tableRows+'</table>'
          +'<div class="cj-example">ex. '+card.ex+'</div>'
          +'<div class="cj-vosotros-note">* vosotros = Espagne uniquement — Amérique latine → ustedes</div>'
          +'</div>'
          +'</div>'
          +'</div>'
          +navOrRate;
      }

      function cjFlip(){cFlipped=!cFlipped;renderCj();}
      function setCjTense(t){currentTense=t;buildCjDeck();}
      function setCjVerb(v){currentVerb=v;buildCjDeck();}
      function cjPrev(){if(cIdx>0){cIdx--;cFlipped=false;renderCj();}}
      function cjRate(r){cScores[r]++;cIdx++;cFlipped=false;renderCj();}

      window.buildCjDeck=buildCjDeck;
      window.cjFlip=cjFlip;
      window.setCjTense=setCjTense;
      window.setCjVerb=setCjVerb;
      window.cjPrev=cjPrev;
      window.cjRate=cjRate;

      buildCjDeck();
    })();
    </script>
  </main>
</Layout>
