        {id:"imperf", label:"Pretérito imperfecto",  fr:"Imparfait",                   usage:"both",  note:"Description ou habitude dans le passé. Sert à planter le décor ou l'ambiance d'un récit."},
        {id:"perf",   label:"Pretérito perfecto",    fr:"Passé composé (oral Espagne)", usage:"oral", note:"Passé récent lié au présent. Très utilisé à l'oral en Espagne. En Amérique latine → indéfini."},
        {id:"periph", label:"Futuro perifrástico",   fr:"Futur proche (ir a + inf.)",  usage:"oral",  note:"Futur proche ou planifié. Le futur le plus fréquent à l'oral. Équivalent de aller + infinitif."},
        {id:"fut",    label:"Futuro simple",         fr:"Futur simple (formel)",       usage:"ecrit", note:"Futur ou supposition. Plus formel. Souvent remplacé par le futur périphrastique à l'oral."},
        {id:"cond",   label:"Condicional",           fr:"Conditionnel",                usage:"both",  note:"Politesse, hypothèse ou conseil. Équivalent exact du conditionnel français. Incontournable."},
      ];

      const VD = {
        hablar:{type:"régulier -ar",
          pres:["hablo","hablas","habla","hablamos","habláis","hablan"],
          indef:["hablé","hablaste","habló","hablamos","hablasteis","hablaron"],
          imperf:["hablaba","hablabas","hablaba","hablábamos","hablabais","hablaban"],
          perf:["he hablado","has hablado","ha hablado","hemos hablado","habéis hablado","han hablado"],
          periph:["voy a hablar","vas a hablar","va a hablar","vamos a hablar","vais a hablar","van a hablar"],
