---
import Layout from "../components/Layout.astro";
---

<Layout title="Flashcards Espagnol" description="200+ mots espagnols les plus courants en mode flashcards interactives — style Anki">
  <main>
    <h2>Flashcards Espagnol</h2>

    <style is:global>
      .fc-wrap * { box-sizing: border-box; }
      .fc-wrap { padding: 1rem 0; font-family: system-ui, sans-serif; }
      .stats-row { display: flex; gap: 8px; margin-bottom: 1rem; }
      .stat { background: #f5f5f3; border-radius: 8px; padding: 10px 16px; flex: 1; text-align: center; }
      .stat-val { font-size: 20px; font-weight: 500; }
      .stat-lbl { font-size: 12px; color: #888; margin-top: 2px; }
      .controls-row { display: flex; gap: 8px; margin-bottom: 1rem; flex-wrap: wrap; align-items: center; }
      .cat-select, .mode-btn, .shuffle-btn { padding: 6px 12px; font-size: 13px; border-radius: 8px; border: 0.5px solid #ccc; background: #fff; cursor: pointer; }
      .mode-btn.active { background: #f0f0ee; font-weight: 500; border-color: #999; }
      .progress-bar-bg { background: #e5e5e5; border-radius: 4px; height: 4px; margin-bottom: 1.25rem; }
      .progress-bar-fill { height: 4px; border-radius: 4px; background: #1D9E75; transition: width .3s; }
      .card-scene { perspective: 1000px; width: 100%; height: 220px; cursor: pointer; margin-bottom: 1rem; }
      .card-3d { width: 100%; height: 100%; position: relative; transform-style: preserve-3d; transition: transform .45s cubic-bezier(.4,0,.2,1); }
      .card-3d.flipped { transform: rotateY(180deg); }
      .card-face { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; border-radius: 12px; border: 0.5px solid #ddd; background: #fff; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; }
      .card-face.back { transform: rotateY(180deg); background: #f9f9f7; }
      .card-cat { font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }
      .card-word { font-size: 36px; font-weight: 500; margin-bottom: 6px; }
      .card-phonetic { font-size: 13px; color: #888; font-style: italic; }
      .card-translation { font-size: 28px; font-weight: 500; margin-bottom: 8px; }
      .card-example { font-size: 13px; color: #666; text-align: center; line-height: 1.5; }
      .card-num { font-size: 12px; color: #aaa; text-align: center; margin-bottom: 6px; }
      .nav-row, .rate-row { display: flex; gap: 8px; justify-content: center; margin-bottom: 1rem; }
      .nav-btn { padding: 8px 20px; font-size: 14px; border-radius: 8px; border: 0.5px solid #ccc; background: #fff; cursor: pointer; }
      .nav-btn:hover { background: #f5f5f3; }
      .rate-btn { padding: 8px 18px; font-size: 13px; border-radius: 8px; border: 0.5px solid #ccc; cursor: pointer; font-weight: 500; }
      .rate-easy { background: #EAF3DE; color: #3B6D11; border-color: #C0DD97; }
      .rate-hard { background: #FAECE7; color: #993C1D; border-color: #F5C4B3; }
      .rate-skip { background: #f5f5f3; color: #666; }
      .done-panel { text-align: center; padding: 2rem; }
      .done-panel h3 { font-size: 20px; font-weight: 500; margin-bottom: .5rem; }
      .done-panel p { color: #666; font-size: 14px; margin-bottom: 1rem; }
      @media (prefers-color-scheme: dark) {
        .stat, .mode-btn.active, .rate-skip, .nav-btn:hover { background: #2a2a28; }
        .card-face { background: #1e1e1c; border-color: #333; }
        .card-face.back { background: #252523; }
        .cat-select, .mode-btn, .shuffle-btn, .nav-btn { background: #1e1e1c; color: #eee; border-color: #444; }
        .progress-bar-bg { background: #333; }
      }
    </style>

