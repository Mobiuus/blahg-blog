        {cat:"directions",es:"arriba",fr:"en haut",ph:"ariba",ex:"Está arriba — C'est en haut"},
        {cat:"directions",es:"abajo",fr:"en bas",ph:"abaHo",ex:"Está abajo — C'est en bas"},
        {cat:"directions",es:"enfrente",fr:"en face",ph:"énfrenté",ex:"Está enfrente — C'est en face"},
        // MÉTÉO
        {cat:"météo",es:"hace calor",fr:"il fait chaud",ph:"asé kalor",ex:"Hoy hace mucho calor — Il fait très chaud aujourd'hui"},
        {cat:"météo",es:"hace frío",fr:"il fait froid",ph:"asé frio",ex:"Hace mucho frío — Il fait très froid"},
        {cat:"météo",es:"llueve",fr:"il pleut",ph:"youévé",ex:"Está lloviendo — Il est en train de pleuvoir"},
        {cat:"météo",es:"el sol",fr:"le soleil",ph:"sol",ex:"Hace sol — Il y a du soleil"},
        {cat:"météo",es:"nublado",fr:"nuageux / couvert",ph:"noublado",ex:"Está nublado — C'est couvert"},
        {cat:"météo",es:"el viento",fr:"le vent",ph:"viénto",ex:"Hace mucho viento — Il y a beaucoup de vent"},
      ];

      const CATS = ["tous", ...Array.from(new Set(ALL_CARDS.map(c => c.cat)))];
      let deck = [], idx = 0, flipped = false, mode = "es→fr";
      let scores = {easy:0, hard:0, skip:0};

      function shuffle(arr) {
        const a = [...arr];
        for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}
        return a;
      }

      function buildDeck(cat) {
        deck = shuffle(cat === "tous" ? ALL_CARDS : ALL_CARDS.filter(c => c.cat === cat));
        idx = 0; flipped = false; scores = {easy:0,hard:0,skip:0};
        render();
      }

      function currentCat() {
        const s = document.getElementById('catSel');
        return s ? s.value : "tous";
      }

      function render() {
        const app = document.getElementById('fc-app');
        if (idx >= deck.length) {
          app.innerHTML = `<div class="done-panel"><h3>Deck terminé !</h3><p>Facile : ${scores.easy} · Difficile : ${scores.hard} · Passé : ${scores.skip}</p><div class="nav-row"><button class="nav-btn" onclick="buildDeck(currentCat())">Recommencer</button></div></div>`;
          return;
        }
        const card = deck[idx];
        const front = mode === "es→fr" ? card.es : card.fr;
        const back  = mode === "es→fr" ? card.fr : card.es;
        const pct = Math.round(idx / deck.length * 100);
        app.innerHTML = `
          <div class="stats-row">
            <div class="stat"><div class="stat-val">${deck.length}</div><div class="stat-lbl">cartes</div></div>
            <div class="stat"><div class="stat-val">${idx}</div><div class="stat-lbl">vues</div></div>
            <div class="stat"><div class="stat-val" style="color:#3B6D11">${scores.easy}</div><div class="stat-lbl">faciles</div></div>
            <div class="stat"><div class="stat-val" style="color:#993C1D">${scores.hard}</div><div class="stat-lbl">difficiles</div></div>
          </div>
          <div class="controls-row">
            <select class="cat-select" id="catSel" onchange="buildDeck(this.value)">
              ${CATS.map(c=>`<option value="${c}"${c===currentCat()?' selected':''}>${c}</option>`).join('')}
            </select>
            <button class="mode-btn${mode==='es→fr'?' active':''}" onclick="setMode('es→fr')">ES → FR</button>
            <button class="mode-btn${mode==='fr→es'?' active':''}" onclick="setMode('fr→es')">FR → ES</button>
            <button class="shuffle-btn" onclick="buildDeck(currentCat())">Mélanger</button>
          </div>
          <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:${pct}%"></div></div>
          <div class="card-num">${idx+1} / ${deck.length}</div>
          <div class="card-scene" onclick="flipCard()">
            <div class="card-3d${flipped?' flipped':''}">
              <div class="card-face front">
                <div class="card-cat">${card.cat}</div>
                <div class="card-word">${front}</div>
                ${mode==='es→fr'&&card.ph?`<div class="card-phonetic">[${card.ph}]</div>`:''}
                <div style="font-size:12px;color:#aaa;margin-top:12px">Cliquer pour retourner</div>
              </div>
              <div class="card-face back">
                <div class="card-cat">${card.cat}</div>
                <div class="card-translation">${back}</div>
                <div class="card-example">${card.ex}</div>
              </div>
            </div>
          </div>
          ${flipped ? `
          <div class="rate-row">
            <button class="rate-btn rate-hard" onclick="rate('hard')">Difficile</button>
            <button class="rate-btn rate-skip" onclick="rate('skip')">Passer</button>
            <button class="rate-btn rate-easy" onclick="rate('easy')">Facile</button>
          </div>` : `
          <div class="nav-row">
            <button class="nav-btn" onclick="prevCard()"${idx===0?' disabled':''}>← Préc.</button>
            <button class="nav-btn" onclick="flipCard()">Retourner</button>
            <button class="nav-btn" onclick="rate('skip')">Suivant →</button>
          </div>`}`;
      }

      function flipCard() { flipped = !flipped; render(); }
      function setMode(m) { mode = m; buildDeck(currentCat()); }
      function prevCard() { if(idx>0){idx--;flipped=false;render();} }
      function rate(r) { scores[r]++; idx++; flipped=false; render(); }

      buildDeck("tous");
    </script>
  </main>
</Layout>
