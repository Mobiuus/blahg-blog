---
import Layout from "../components/Layout.astro";
import { SITE_TITLE } from "../config";
---

<Layout title={`Trafic | ${SITE_TITLE}`} description="Prochains passages métro et RER">
  <div class="trafic-page">
    <div class="board" id="board">
      <div class="board-loading" id="board-loading">
        <span class="dot">·</span><span class="dot">·</span><span class="dot">·</span>
      </div>
    </div>
    <p class="board-footer" id="board-footer"></p>
  </div>
</Layout>

<script>
  // ── PRIM IDFM API ──
  // Get a free key at https://prim.iledefrance-mobilites.fr/
  // Then add PUBLIC_PRIM_API_KEY=your_key to .env
  const API_KEY = import.meta.env.PUBLIC_PRIM_API_KEY;
  const PRIM_URL = "https://prim.iledefrance-mobilites.fr/marketplace/stop-monitoring";

  // ── Official RATP line colors ──
  interface LineConfig {
    label: string;
    type: "metro" | "rer";
    stopRef: string;
    lineRef: string;
    color: string;
    textColor: string;
    altStation?: string;
  }

  interface StationConfig {
    name: string;
    lines: LineConfig[];
  }

  // Stop IDs from https://data.iledefrance-mobilites.fr (dataset arrets-lignes)
  // MonitoringRef format: STIF:StopPoint:Q:{id}: for metro, STIF:StopArea:SP:{id}: for RER
  const STATIONS: StationConfig[] = [
    {
      name: "Madeleine",
      lines: [
        { label: "8",  type: "metro", stopRef: "STIF:StopPoint:Q:22194:", lineRef: "STIF:Line::C01378:", color: "#D282BE", textColor: "#000" },
        { label: "12", type: "metro", stopRef: "STIF:StopPoint:Q:21965:", lineRef: "STIF:Line::C01382:", color: "#007852", textColor: "#fff" },
        { label: "14", type: "metro", stopRef: "STIF:StopPoint:Q:21961:", lineRef: "STIF:Line::C01384:", color: "#68217A", textColor: "#fff" },
      ],
    },
    {
      name: "Concorde",
      lines: [
        { label: "1", type: "metro", stopRef: "STIF:StopPoint:Q:22085:", lineRef: "STIF:Line::C01371:", color: "#FFBE00", textColor: "#000" },
      ],
    },
    {
      name: "Opéra",
      lines: [
        { label: "3", type: "metro", stopRef: "STIF:StopPoint:Q:22030:", lineRef: "STIF:Line::C01373:", color: "#9B993A", textColor: "#fff" },
        { label: "9", type: "metro", stopRef: "STIF:StopPoint:Q:21926:", lineRef: "STIF:Line::C01379:", color: "#CDC83F", textColor: "#000", altStation: "Havre - Caumartin" },
        { label: "A", type: "rer",   stopRef: "STIF:StopArea:SP:45873:", lineRef: "STIF:Line::C01742:", color: "#E2231A", textColor: "#fff", altStation: "Auber" },
      ],
    },
  ];

  // ── Types ──
  interface Departure {
    destination: string;
    minutes: number;
  }

  // ── SIRI response parser ──
  function parseDepartures(data: any): Departure[] {
    const now = Date.now();
    const delivery = data?.Siri?.ServiceDelivery?.StopMonitoringDelivery;
    const visits = delivery?.[0]?.MonitoredStopVisit ?? [];

    return visits
      .map((v: any) => {
        const j = v?.MonitoredVehicleJourney;
        const call = j?.MonitoredCall;
        const destination =
          call?.DestinationDisplay?.[0]?.value ??
          j?.DestinationName?.[0]?.value ??
          "—";
        const timeStr = call?.ExpectedDepartureTime ?? call?.ExpectedArrivalTime;
        if (!timeStr) return null;
        const minutes = Math.round((new Date(timeStr).getTime() - now) / 60_000);
        if (minutes < 0) return null;
        return { destination, minutes } as Departure;
      })
      .filter(Boolean) as Departure[];
  }

  // ── Fetch one stop/line combo ──
  async function fetchLine(stopRef: string, lineRef: string): Promise<Departure[]> {
    const encodedRef = encodeURIComponent(stopRef);
    const params = new URLSearchParams({ LineRef: lineRef });
    const res = await fetch(`${PRIM_URL}/${encodedRef}?${params}`, {
      headers: { apikey: API_KEY },
    });
    if (!res.ok) return [];
    return parseDepartures(await res.json());
  }

  // ── Group departures by destination, keep first N per group ──
  function groupByDest(deps: Departure[], perDest = 2): [string, Departure[]][] {
    const map = new Map<string, Departure[]>();
    for (const d of deps.sort((a, b) => a.minutes - b.minutes)) {
      const arr = map.get(d.destination) ?? [];
      if (arr.length < perDest) {
        arr.push(d);
        map.set(d.destination, arr);
      }
    }
    return [...map.entries()];
  }

  // ── Format time display ──
  function fmtTime(min: number): string {
    if (min === 0) return "à quai";
    if (min === 1) return "1 mn";
    return `${min} mn`;
  }

  // ── Render ──
  function renderBoard(allResults: Departure[][]): string {
    let idx = 0;
    return STATIONS.map((station) => {
      const lineBlocks = station.lines.map((line) => {
        const deps = allResults[idx++];
        const groups = groupByDest(deps);
        const badgeCls = line.type === "rer" ? "badge rer" : "badge";
        const altHtml = line.altStation
          ? `<span class="alt-station">${line.altStation}</span>`
          : "";

        const rows =
          groups.length === 0
            ? `<div class="dep-row"><span class="dep-dest no-data">pas de passage</span></div>`
            : groups
                .map(
                  ([dest, deps]) => `
              <div class="dep-row">
                <span class="dep-dest">${dest}</span>
                <span class="dep-times">
                  ${deps
                    .map(
                      (d, i) =>
                        `<span class="dep-time${i > 0 ? " next" : ""}${d.minutes <= 1 ? " urgent" : ""}">${fmtTime(d.minutes)}</span>`
                    )
                    .join("")}
                </span>
              </div>`
                )
                .join("");

        return `
          <div class="line-block">
            <div class="${badgeCls}" style="background:${line.color};color:${line.textColor}">${line.label}</div>
            <div class="line-deps">
              ${altHtml}
              ${rows}
            </div>
          </div>`;
      }).join("");

      return `
        <div class="station">
          <div class="station-hdr"><h2>${station.name}</h2></div>
          ${lineBlocks}
        </div>`;
    }).join("");
  }

  // ── Main ──
  async function init() {
    const board = document.getElementById("board");
    const footer = document.getElementById("board-footer");
    if (!board) return;

    if (!API_KEY) {
      board.innerHTML = `
        <div class="board-msg">
          <p>Clé API PRIM manquante</p>
          <p class="board-hint">
            1. Crée un compte sur <a href="https://prim.iledefrance-mobilites.fr/" target="_blank">prim.iledefrance-mobilites.fr</a><br>
            2. Ajoute <code>PUBLIC_PRIM_API_KEY=ta_clé</code> dans <code>.env</code>
          </p>
        </div>`;
      return;
    }

    try {
      const tasks = STATIONS.flatMap((s) =>
        s.lines.map((l) => fetchLine(l.stopRef, l.lineRef))
      );
      const results = await Promise.all(tasks);
      board.innerHTML = renderBoard(results);

      if (footer) {
        const now = new Date();
        footer.textContent = `${now.getHours().toString().padStart(2, "0")}:${now.getMinutes().toString().padStart(2, "0")}`;
      }
    } catch (e) {
      board.innerHTML = `<div class="board-msg"><p>erreur de chargement</p><p class="board-hint">${e}</p></div>`;
    }
  }

  init();
</script>

<style>
  /* ── Page ── */
  .trafic-page {
    padding: 1rem 0 3rem;
  }

  /* ── Dark board container ── */
  .board {
    background: #0a0a0f;
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
    min-height: 120px;
  }

  /* ── Loading dots ── */
  .board-loading {
    display: flex;
    gap: 4px;
    color: #444;
    font-size: 2.5rem;
    padding: 2rem 0;
  }
  .dot {
    animation: pulse 1.2s ease-in-out infinite;
  }
  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes pulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }

  /* ── Station ── */
  .station {
    margin-bottom: 1.75rem;
  }
  .station:last-child {
    margin-bottom: 0;
  }

  .station-hdr h2 {
    color: #fff;
    font-size: 0.8rem;
    font-weight: bold;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #0E0184;
  }

  /* ── Line block: badge + departures ── */
  .line-block {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.4rem 0;
  }

  .badge {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 1px;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .badge.rer {
    border-radius: 5px;
  }

  .alt-station {
    color: #444;
    font-size: 0.7rem;
    font-style: italic;
    display: block;
    margin-bottom: 2px;
  }

  .line-deps {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  /* ── Departure row ── */
  .dep-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .dep-dest {
    color: #999;
    font-size: 0.85rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }
  .dep-dest.no-data {
    color: #444;
    font-style: italic;
  }

  .dep-times {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    align-items: baseline;
  }

  .dep-time {
    color: #FFBE00;
    font-weight: bold;
    font-size: 1.05rem;
    min-width: 5ch;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .dep-time.next {
    opacity: 0.35;
    font-size: 0.85rem;
  }
  .dep-time.urgent {
    animation: blink 1.4s step-start infinite;
  }

  @keyframes blink {
    50% { opacity: 0.3; }
  }

  /* ── Footer timestamp ── */
  .board-footer {
    color: var(--gray);
    font-size: 0.75rem;
    margin-top: 0.75rem;
    text-align: right;
  }

  /* ── Error/setup message ── */
  .board-msg {
    padding: 1.5rem 0;
  }
  .board-msg p {
    color: #ccc;
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
  }
  .board-msg .board-hint {
    color: #666;
    font-size: 0.8rem;
    line-height: 1.6;
  }
  .board-msg a {
    color: #FFBE00;
    text-decoration-color: #FFBE0060;
  }
  .board-msg code {
    background: #1a1a2e;
    color: #aaa;
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.78rem;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .board {
      border-radius: 8px;
      padding: 1rem 1.25rem;
    }
    .badge {
      width: 1.75rem;
      height: 1.75rem;
      font-size: 0.8rem;
    }
    .dep-time {
      font-size: 0.95rem;
      min-width: 4ch;
    }
  }
</style>
