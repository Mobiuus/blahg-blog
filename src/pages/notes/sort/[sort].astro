---
import type { GetStaticPaths } from "astro";
import Layout from "@/components/Layout.astro";
import NotesPage from "@/components/notes/NotesPage.astro";
import {
  NOTE_SORT_VALUES,
  getCategories,
  normalizeNote,
  sortNotes,
  type NoteSort,
} from "@/lib/notes";

export const getStaticPaths: GetStaticPaths = async () =>
  NOTE_SORT_VALUES.map((sort) => ({ params: { sort } }));

const selectedSort = Astro.params.sort as NoteSort;

if (!NOTE_SORT_VALUES.includes(selectedSort)) {
  return Astro.redirect("/notes");
}

const loadRawNotes = async () => {
  try {
    return await Astro.glob("../../../notes/*.md");
  } catch {
    return [];
  }
};

const rawNotes = await loadRawNotes();
const notes = rawNotes.map(normalizeNote);
const categories = getCategories(notes);
const sortedNotes = sortNotes(notes, selectedSort);
---

<Layout title="Notes" description="Living notes and ideas in progress">
  <NotesPage
    notes={sortedNotes}
    categories={categories}
    selectedSort={selectedSort}
  />
</Layout>
