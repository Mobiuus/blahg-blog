---
import type { GetStaticPaths } from "astro";
import Layout from "@/components/Layout.astro";
import NotesPage from "@/components/notes/NotesPage.astro";
import {
  findCategoryNameBySlug,
  getCategories,
  normalizeNote,
  slugify,
  sortNotes,
  type NoteSort,
} from "@/lib/notes";

export const getStaticPaths: GetStaticPaths = async () => {
  const rawNotes = await (async () => {
    try {
      return await Astro.glob("../../notes/*.md");
    } catch {
      return [];
    }
  })();
  const notes = rawNotes.map(normalizeNote);
  const categories = getCategories(notes);
  return categories.map((category) => ({
    params: { category: category.slug },
  }));
};

const categorySlug = Astro.params.category || "";
const selectedSort: NoteSort = "newest";

const rawNotes = await (async () => {
  try {
    return await Astro.glob("../../notes/*.md");
  } catch {
    return [];
  }
})();
const notes = rawNotes.map(normalizeNote);
const categories = getCategories(notes);
const categoryName = findCategoryNameBySlug(categories, categorySlug);

if (!categoryName) {
  return Astro.redirect("/notes");
}

const filteredNotes = notes.filter((note) => slugify(note.thema) === categorySlug);
const sortedNotes = sortNotes(filteredNotes, selectedSort);
---

<Layout title={`Notes: ${categoryName}`} description="Living notes and ideas in progress">
  <NotesPage
    notes={sortedNotes}
    categories={categories}
    selectedCategory={categorySlug}
    selectedSort={selectedSort}
  />
</Layout>
