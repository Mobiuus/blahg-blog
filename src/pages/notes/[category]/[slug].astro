---
import type { GetStaticPaths, MarkdownInstance } from "astro";
import Layout from "@/components/Layout.astro";
import {
  formatDisplayDate,
  normalizeNote,
  slugify,
  sortNotes,
  type NoteFrontmatter,
} from "@/lib/notes";
import { colors } from "@/components/notes/utils/colors";

interface Props {
  note: ReturnType<typeof normalizeNote>;
  previousNote: ReturnType<typeof normalizeNote> | null;
  nextNote: ReturnType<typeof normalizeNote> | null;
  Content: MarkdownInstance<NoteFrontmatter>["Content"];
  bgColor: string;
}

export const getStaticPaths: GetStaticPaths = async () => {
  const rawNotes: MarkdownInstance<NoteFrontmatter>[] = await (async () => {
    try {
      return await Astro.glob("../../../notes/*.md");
    } catch {
      return [];
    }
  })();
  const normalizedNotes = rawNotes.map(normalizeNote);

  // Assign colors: sort categories by note count (most first) for consistent palette
  const categoryCounts = new Map<string, number>();
  for (const note of normalizedNotes) {
    categoryCounts.set(note.thema, (categoryCounts.get(note.thema) || 0) + 1);
  }
  const categoryColorIndex: Record<string, number> = {};
  [...categoryCounts.entries()]
    .sort((a, b) => b[1] - a[1])
    .forEach(([name], idx) => {
      categoryColorIndex[name] = idx;
    });

  return rawNotes.map((rawNote) => {
    const currentNote = normalizeNote(rawNote);
    const categoryNotes = sortNotes(
      normalizedNotes.filter(
        (n) => slugify(n.thema) === slugify(currentNote.thema),
      ),
      "newest",
    );
    const idx = categoryNotes.findIndex((n) => n.slug === currentNote.slug);
    const colorIdx = categoryColorIndex[currentNote.thema] ?? 0;

    return {
      params: {
        category: slugify(currentNote.thema),
        slug: currentNote.slug,
      },
      props: {
        note: currentNote,
        previousNote: idx > 0 ? categoryNotes[idx - 1] : null,
        nextNote: idx < categoryNotes.length - 1 ? categoryNotes[idx + 1] : null,
        Content: rawNote.Content,
        bgColor: colors[colorIdx % colors.length],
      },
    };
  });
};

const { note, previousNote, nextNote, Content, bgColor } = Astro.props as Props;
const showEdited =
  note.edited &&
  formatDisplayDate(note.created) !== formatDisplayDate(note.edited);
---

<Layout title={note.title} description={note.description}>
  <!-- SVG distortion filter for metadata display -->
  <svg
    style="position:absolute;width:0;height:0;overflow:hidden;"
    aria-hidden="true"
  >
    <defs>
      <filter id="distort-xl">
        <feTurbulence baseFrequency="1 1" numOctaves="1"></feTurbulence>
        <feDisplacementMap in="SourceGraphic" scale="1.3"></feDisplacementMap>
      </filter>
    </defs>
  </svg>

  <div class="note-page-outer">
    <div class="back-row">
      <a href="/notes" class="back-link">← Back to notes</a>
    </div>

    <article class="note-article" style={`background-color: ${bgColor};`}>
      <div class="note-texture" aria-hidden="true"></div>

      <div class="note-inner">
        <!-- Content with border -->
        <div class="content-box">
          <div class="note-top">
            <h1 class="note-title">{note.title}</h1>
            <div class="title-rule"></div>
          </div>
          <div class="note-prose">
            <Content />
          </div>
        </div>

        <!-- Metadata footer (shares left/right/bottom border with content-box) -->
        <div class="note-footer">
          <div class="meta-row">
            <span
              class:list={[
                "meta-cell",
                showEdited ? "cell-third" : "cell-half",
              ]}
            >
              <span class="meta-label">Created:</span>
              <span class="meta-value" style="filter: url(#distort-xl);">
                {formatDisplayDate(note.created)}
              </span>
            </span>
            {showEdited && note.edited && (
              <span class="meta-cell cell-third meta-cell--border">
                <span class="meta-label">Edited:</span>
                <span class="meta-value" style="filter: url(#distort-xl);">
                  {formatDisplayDate(note.edited)}
                </span>
              </span>
            )}
            <span
              class:list={[
                "meta-cell",
                "meta-cell--border",
                showEdited ? "cell-third" : "cell-half",
              ]}
            >
              <span class="meta-label">Topic:</span>
              <span class="meta-value" style="filter: url(#distort-xl);">
                {note.thema}
              </span>
            </span>
          </div>

          {(previousNote || nextNote) && (
            <div class="note-nav">
              {previousNote ? (
                <a
                  href={`/notes/${slugify(note.thema)}/${previousNote.slug}`}
                  class:list={["nav-link", nextNote && "nav-link--half"]}
                >
                  ← Previous note
                </a>
              ) : null}
              {nextNote && (
                <a
                  href={`/notes/${slugify(note.thema)}/${nextNote.slug}`}
                  class:list={[
                    "nav-link",
                    previousNote && "nav-link--half",
                    previousNote && "nav-link--right",
                  ]}
                >
                  Next note →
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </article>
  </div>
</Layout>

<!-- Prevent horizontal scroll caused by full-bleed escape -->
<style is:global>
  html:has(.note-page-outer) {
    overflow-x: hidden;
  }
</style>

<style>
  /* Full-bleed escape from 70ch body constraint */
  .note-page-outer {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  .back-row {
    padding: 1rem 1.5rem 0.75rem;
  }

  .back-link {
    color: var(--text-color);
    text-decoration: underline;
    font-size: 0.9rem;
  }

  /* Colored article card */
  .note-article {
    position: relative;
    width: 100%;
    color: #000;
    padding-bottom: 1.5rem;
  }

  /* Noise texture overlay */
  .note-texture {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    mix-blend-mode: soft-light;
    pointer-events: none;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 369 369' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.5' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }

  /* Centered inner wrapper */
  .note-inner {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* Content area with full border */
  .content-box {
    border: 1px solid rgba(0, 0, 0, 0.45);
    padding: 1.5rem 1.5rem 4rem;
    margin-top: 8px;
  }

  @media (min-width: 640px) {
    .content-box {
      padding: 2rem 2.5rem 5rem;
    }
  }

  .note-top {
    max-width: 65ch;
    margin: 2rem auto 0;
  }

  .note-title {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    color: #000 !important;
    text-decoration: none;
    margin: 0 0 0.75rem;
  }

  .title-rule {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.4);
    margin: 0.75rem 0 2rem;
  }

  /* Note markdown content */
  .note-prose {
    max-width: 65ch;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.7;
    color: #000;
  }

  .note-prose :global(h1),
  .note-prose :global(h2),
  .note-prose :global(h3),
  .note-prose :global(h4),
  .note-prose :global(h5),
  .note-prose :global(h6) {
    color: #000;
    text-decoration: none;
  }

  .note-prose :global(p),
  .note-prose :global(li),
  .note-prose :global(td) {
    color: rgba(0, 0, 0, 0.9);
  }

  .note-prose :global(a) {
    color: rgba(0, 0, 0, 0.75);
    border-bottom: 1px dashed rgba(0, 0, 0, 0.35);
    text-decoration: none;
    padding-bottom: 1px;
  }

  .note-prose :global(a:hover) {
    color: #000;
    border-bottom-color: rgba(0, 0, 0, 0.7);
    text-decoration: none;
  }

  .note-prose :global(blockquote) {
    border-left: 3px solid rgba(0, 0, 0, 0.3);
    border-color: rgba(0, 0, 0, 0.3);
    background-color: rgba(0, 0, 0, 0.04);
    color: rgba(0, 0, 0, 0.8);
  }

  .note-prose :global(code) {
    background-color: rgba(0, 0, 0, 0.08);
    color: #000;
  }

  .note-prose :global(hr) {
    border-color: rgba(0, 0, 0, 0.25);
  }

  /* Footer: left/right/bottom border (top from content-box) */
  .note-footer {
    border-left: 1px solid rgba(0, 0, 0, 0.45);
    border-right: 1px solid rgba(0, 0, 0, 0.45);
    border-bottom: 1px solid rgba(0, 0, 0, 0.45);
    margin-bottom: 8px;
  }

  .meta-row {
    display: flex;
    border-bottom: 1px solid rgba(0, 0, 0, 0.45);
  }

  .meta-cell {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0.75rem 1rem;
  }

  @media (min-width: 480px) {
    .meta-cell {
      flex-direction: row;
      align-items: center;
      gap: 0.6rem;
    }
  }

  .cell-half {
    width: 50%;
  }

  .cell-third {
    width: 33.33%;
  }

  .meta-cell--border {
    border-left: 1px solid rgba(0, 0, 0, 0.45);
  }

  .meta-label {
    color: rgba(0, 0, 0, 0.55);
    font-size: 0.85rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .meta-value {
    font-style: italic;
    font-size: 1rem;
    color: #000;
    font-weight: 600;
  }

  @media (min-width: 480px) {
    .meta-value {
      font-size: 1.15rem;
    }
  }

  /* Prev / next navigation */
  .note-nav {
    display: flex;
  }

  .nav-link {
    display: block;
    width: 100%;
    padding: 1.75rem 1rem;
    text-align: center;
    text-decoration: none !important;
    color: #000;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .nav-link:hover {
    background-color: rgba(0, 0, 0, 0.06);
    text-decoration: none !important;
  }

  .nav-link--half {
    width: 50%;
  }

  .nav-link--right {
    border-left: 1px solid rgba(0, 0, 0, 0.45);
  }
</style>
