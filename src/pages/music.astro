---
import Layout from "../components/Layout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../config";

const LASTFM_API_KEY = "e8f7cc2bf5c0782e9f79cc243a7fe496";
const LASTFM_USER = "VaKaas";

interface AlbumDetails {
  title: string;
  artist: string;
  cover: string;
  playCount: number;
}

async function fetchTopAlbums(period: string, limit: number = 5): Promise<AlbumDetails[]> {
  const url = `https://ws.audioscrobbler.com/2.0/?method=user.gettopalbums&user=${LASTFM_USER}&api_key=${LASTFM_API_KEY}&period=${period}&limit=${limit}&format=json`;
  const res = await fetch(url);
  if (!res.ok) throw new Error(`Last.fm error: ${res.status}`);
  const data = await res.json();
  return (data.topalbums?.album ?? []).map((a: any) => ({
    title: a.name,
    artist: a.artist.name,
    cover: a.image?.find((img: any) => img.size === "extralarge")?.["#text"] ?? "",
    playCount: parseInt(a.playcount, 10) || 0,
  }));
}

async function fetchRegistrationYear(): Promise<number> {
  const url = `https://ws.audioscrobbler.com/2.0/?method=user.getinfo&user=${LASTFM_USER}&api_key=${LASTFM_API_KEY}&format=json`;
  const res = await fetch(url);
  if (!res.ok) return new Date().getFullYear();
  const data = await res.json();
  const unixtime = data?.user?.registered?.unixtime;
  return unixtime ? new Date(unixtime * 1000).getFullYear() : new Date().getFullYear();
}

function hashString(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) - hash) + str.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash);
}

const discColors = ["#ff8477", "#6ad09d", "#b3cdfb", "#ffc700", "#c6b9ff", "#635c7f", "#ffc1bb"];

let monthly: AlbumDetails[] = [];
let yearly: AlbumDetails[] = [];
let overall: AlbumDetails[] = [];
let since: number = new Date().getFullYear();
let error: string | null = null;

try {
  [monthly, yearly, overall, since] = await Promise.all([
    fetchTopAlbums("1month"),
    fetchTopAlbums("12month"),
    fetchTopAlbums("overall"),
    fetchRegistrationYear(),
  ]);
} catch (e) {
  error = e instanceof Error ? e.message : "Unknown error";
}

const sections = [
  { label: "Last 30 days", albums: monthly },
  { label: "Last 365 days", albums: yearly },
  { label: "All time", albums: overall },
];
---

<Layout title={`Music | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <main>
    <div class="music-page">
      <p class="intro">Since {since}</p>

      {error && <p class="error">Failed to load: {error}</p>}

      {!error && sections.map(({ label, albums }) => (
        <section class="carousel-section">
          <h2>{label}</h2>
          {albums.length === 0 ? (
            <p class="empty">No data yet.</p>
          ) : (
            <div class="carousel">
              {albums.map((album) => {
                const colorIndex = hashString(album.title + album.artist) % discColors.length;
                const discColor = discColors[colorIndex];
                return (
                  <div class="album-item">
                    <div class="album-card">
                      <div class="album-wrap">
                        <div
                          class="album-cover"
                          style={album.cover ? `background-image: url(${album.cover})` : ""}
                        />
                        <div class="disk" style={`--disc-color: ${discColor}`}>
                          <div class="disk-inside" />
                        </div>
                      </div>
                    </div>
                    <div class="album-info">
                      <p class="album-title">{album.title}</p>
                      <p class="album-artist">{album.artist}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </section>
      ))}
    </div>
  </main>
</Layout>

<style>
  .music-page {
    padding: 1rem 0 3rem;
  }

  /* Same style as .bookshelf-title */
  .intro {
    text-align: center;
    font-size: 1.2em;
    color: #888;
    margin-bottom: 2rem;
  }

  .error {
    color: var(--red);
  }

  .empty {
    color: var(--gray);
  }

  /* ── Full-bleed carousel section ── */
  /*
   * Breaks out of the 70ch body constraint.
   * margin-left: calc(50% - 50vw + 20px) moves the section to the left
   * until its left edge aligns with viewport-left + 20px.
   * width: calc(100vw - 40px) spans the full viewport minus 2×20px edges.
   */
  .carousel-section {
    width: calc(100vw - 40px);
    margin-left: calc(50% - 50vw + 20px);
    margin-bottom: 3rem;
  }

  .carousel-section h2 {
    margin-bottom: 1.25rem;
  }

  /* ── 5-column grid, no scroll on desktop ── */
  .carousel {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  /* ── Mobile: revert to scroll ── */
  @media (max-width: 600px) {
    .carousel-section {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      padding: 0 20px;
      box-sizing: border-box;
    }
    .carousel {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 0.5rem;
    }
    .album-item {
      flex-shrink: 0;
      scroll-snap-align: start;
      width: 140px;
    }
    .carousel::-webkit-scrollbar { height: 3px; }
    .carousel::-webkit-scrollbar-thumb { background: var(--gray); border-radius: 2px; }
  }

  .album-item {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .album-card {
    background-color: var(--moretransblack);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.75rem 1rem;
    overflow: hidden;
  }

  @media (prefers-color-scheme: dark) {
    .album-card {
      background-color: var(--moretranswhite);
    }
  }

  /* ── Album wrap ── */
  .album-wrap {
    --album-size: 120px;
    --disk-size: 108px;
    position: relative;
    width: var(--album-size);
    height: var(--album-size);
  }

  .album-cover {
    position: absolute;
    z-index: 1;
    border-radius: 2px;
    width: var(--album-size);
    height: var(--album-size);
    background-size: cover;
    background-color: var(--gray);
    transition: all ease-in-out 0.35s;
    box-shadow:
      10px 40px 40px -10px #00000030,
      inset 2px 1px 3px #ffffff60,
      inset 0 -1px 2px #00000080;
  }

  .album-item:hover .album-cover {
    margin-left: -20px;
    box-shadow:
      10px 24px 24px -10px #00000030,
      inset 4px 1px 3px #ffffff60,
      inset 0 -1px 2px #00000080;
  }

  .disk {
    position: absolute;
    width: var(--disk-size);
    height: var(--disk-size);
    border-radius: calc(var(--disk-size) / 2);
    background: #222;
    left: 8px;
    top: 6px;
    transition: margin cubic-bezier(0.6, -0.28, 0.735, 0.045) 0.4s;
    animation: rotating 2.5s linear paused infinite;
    overflow: hidden;
  }

  .disk::after {
    box-sizing: border-box;
    content: "";
    width: calc(var(--disk-size) / 3);
    height: calc(var(--disk-size) / 3);
    border: 16px solid var(--disc-color);
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    margin-top: calc(var(--disk-size) / 6 * -1);
    margin-left: calc(var(--disk-size) / 6 * -1);
  }

  .disk::before {
    box-sizing: border-box;
    content: "";
    position: absolute;
    border: 1px solid rgba(255, 255, 255, 0.2);
    width: calc(var(--disk-size) - 10px);
    height: calc(var(--disk-size) - 10px);
    top: 50%;
    left: 50%;
    border-radius: 50%;
    margin-top: calc((var(--disk-size) - 10px) / -2);
    margin-left: calc((var(--disk-size) - 10px) / -2);
  }

  .disk-inside {
    width: calc(var(--disk-size) / 2);
    height: calc(var(--disk-size) / 2);
    position: absolute;
    top: 0;
    left: 50%;
    background: rgba(255, 255, 255, 0.15);
    filter: blur(2px);
  }

  .album-item:hover .disk {
    margin-left: 40px;
    animation-play-state: running;
    box-shadow: 0px 0px 24px -10px #00000030;
  }

  @keyframes rotating {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ── Info ── */
  .album-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .album-title {
    font-size: 0.8rem;
    font-weight: bold;
    color: var(--text-color);
    line-height: 1.3;
    margin: 0;
  }

  .album-artist {
    font-size: 0.8rem;
    color: var(--gray);
    margin: 0;
  }
</style>
