---
import Layout from "../components/Layout.astro";
import { SITE_TITLE } from "../config";

type Category = "solaire" | "agrivoltaique" | "eolien" | "chaleur" | "stockage" | "autres";

interface Invest {
  developer: string;
  platform: string;
  location: string;
  type: string;
  year: number;
  date: string;
  duration: string;
  capacity: string;
  categories: Category[];
}

const invests: Invest[] = [
  { developer: "Urba 308", platform: "Lendopolis", location: "Rolampont, Haute-Marne (52)", type: "Solaire PV au sol", year: 2025, date: "04/04/2025", duration: "48 mois", capacity: "5,0 MWc", categories: ["solaire"] },
  { developer: "GDSOL 98", platform: "Lendopolis", location: "Doulaincourt-Saucourt, Haute-Marne (52)", type: "Solaire PV au sol", year: 2025, date: "04/04/2025", duration: "42 mois", capacity: "5,7 MWc", categories: ["solaire"] },
  { developer: "TSE Développement", platform: "Enerfip", location: "Multi-régions, France", type: "Solaire PV au sol (portefeuille)", year: 2025, date: "09/05/2025", duration: "42 mois", capacity: "199,8 MWc", categories: ["solaire"] },
  { developer: "Montbéliard Énergies", platform: "Enerfip", location: "Montbéliard, Doubs (25)", type: "Réseau de chaleur (bois-énergie)", year: 2025, date: "21/05/2025", duration: "36 mois", capacity: "N/A", categories: ["chaleur"] },
  { developer: "Solskin 10 (Barconnière)", platform: "Enerfip", location: "Multi-dépts (16, 86, 87, 33, 79)", type: "Solaire PV toiture / hangars agricoles", year: 2025, date: "27/10/2025", duration: "24 mois", capacity: "2,6 MWc", categories: ["solaire"] },
  { developer: "Eco Chaleur du Mantois", platform: "Lendosphère", location: "Mantes-la-Jolie, Yvelines (78)", type: "Réseau de chaleur (extension)", year: 2025, date: "25/11/2025", duration: "36 mois", capacity: "N/A", categories: ["chaleur"] },
  { developer: "Centrale PV de Cosne-sur-Loire", platform: "Lendosphère", location: "Cosne-sur-Loire, Nièvre (58)", type: "Solaire PV au sol", year: 2025, date: "25/11/2025", duration: "42 mois", capacity: "N/A (2 centrales)", categories: ["solaire"] },
  { developer: "Agri Italia Power (Energreen)", platform: "Enerfip", location: "Vallermosa & Samassi, Sardaigne (IT)", type: "Agrivoltaïque", year: 2026, date: "03/01/2026", duration: "24 mois", capacity: "3,0 MWc", categories: ["agrivoltaique", "solaire"] },
  { developer: "Combes de la Romaine (Neoen)", platform: "Lendosphère", location: "Haute-Saône (70)", type: "Éolien terrestre (développement)", year: 2026, date: "22/02/2026", duration: "24 mois", capacity: "N/A", categories: ["eolien"] },
  { developer: "LORIS ENR CEE T2", platform: "Enerfip", location: "France (national)", type: "CEE / BFR (non-production)", year: 2026, date: "03/03/2026", duration: "36 mois", capacity: "N/A", categories: ["autres"] },
  { developer: "Campania Solar T2 (SIG)", platform: "Enerfip", location: "Campanie, Italie", type: "Solaire PV au sol (portefeuille)", year: 2026, date: "07/03/2026", duration: "24 mois", capacity: "137,9 MWc", categories: ["solaire"] },
  { developer: "Solar Reserve T2 (NRG Plus Italia)", platform: "Enerfip", location: "Lombardie, Émilie-Romagne, Pouilles (IT)", type: "PV agrivoltaïque + BESS stockage", year: 2026, date: "07/03/2026", duration: "36 mois", capacity: "~472 MWc", categories: ["agrivoltaique", "solaire", "stockage"] },
  { developer: "Torrente Solar (Kenergy)", platform: "Lendosphère", location: "Communauté Valencienne, Espagne", type: "Solaire PV au sol (4 centrales)", year: 2026, date: "15/03/2026", duration: "36 mois", capacity: "~205 MWc", categories: ["solaire"] },
  { developer: "Mâcon La Grisière (SMEG)", platform: "Lendosphère", location: "Mâcon, Saône-et-Loire (71)", type: "Solaire PV au sol", year: 2026, date: "18/04/2026", duration: "36 mois", capacity: "5,93 MWc", categories: ["solaire"] },
];

// Most recent first
const sorted = [...invests].sort((a, b) => {
  const [da, ma, ya] = a.date.split("/").map(Number);
  const [db, mb, yb] = b.date.split("/").map(Number);
  return new Date(yb, mb - 1, db).getTime() - new Date(ya, ma - 1, da).getTime();
});

interface Cat {
  key: "all" | Category;
  label: string;
  icon: string;
}

const categories: Cat[] = [
  { key: "all",           label: "Tous les projets", icon: "📊" },
  { key: "solaire",       label: "Solaire",          icon: "☀️" },
  { key: "agrivoltaique", label: "Agrivoltaïque",    icon: "🌾" },
  { key: "eolien",        label: "Éolien",           icon: "🌬️" },
  { key: "chaleur",       label: "Réseau de chaleur",icon: "🔥" },
  { key: "stockage",      label: "Stockage (BESS)",  icon: "🔋" },
  { key: "autres",        label: "Autres",           icon: "📄" },
];

function countFor(key: Cat["key"]): number {
  if (key === "all") return invests.length;
  return invests.filter((i) => i.categories.includes(key as Category)).length;
}

function iconFor(type: string): string {
  const t = type.toLowerCase();
  if (t.includes("éolien")) return "🌬️";
  if (t.includes("chaleur")) return "🔥";
  if (t.includes("bess") || t.includes("stockage")) return "🔋";
  if (t.includes("agrivolt")) return "🌾";
  if (t.includes("cee") || t.includes("bfr")) return "📄";
  if (t.includes("solaire") || t.includes("pv")) return "☀️";
  return "⚡";
}
---

<Layout title={`Invest | ${SITE_TITLE}`} description="Mes investissements dans les énergies renouvelables">
  <div class="invest-page">
    <div class="cat-grid" role="tablist" aria-label="Filtrer par catégorie">
      {categories.filter((c) => countFor(c.key) > 0).map((c) => (
        <button
          type="button"
          class="cat-card"
          data-cat={c.key}
          role="tab"
          aria-selected="false"
        >
          <span class="cat-icon" aria-hidden="true">{c.icon}</span>
          <span class="cat-label">{c.label}</span>
          <span class="cat-count">{countFor(c.key)}</span>
        </button>
      ))}
    </div>

    <div class="cards-wrapper" id="cards-wrapper" hidden>
      <div class="cards-head">
        <h2 class="cards-title" id="cards-title">Projets</h2>
        <button type="button" class="cards-close" id="cards-close" aria-label="Fermer">×</button>
      </div>
      <div class="cards" id="cards">
        {sorted.map((p) => (
          <article
            class="card"
            data-cats={p.categories.join(",")}
          >
            <header class="card-head">
              <span class="card-icon" aria-hidden="true">{iconFor(p.type)}</span>
              <div class="card-head-text">
                <h3 class="card-title">{p.developer}</h3>
                <span class="card-platform">{p.platform}</span>
              </div>
              <span class="card-year">{p.year}</span>
            </header>

            <dl class="card-body">
              <div class="row">
                <dt>Lieu</dt>
                <dd>{p.location}</dd>
              </div>
              <div class="row">
                <dt>Type</dt>
                <dd>{p.type}</dd>
              </div>
              <div class="row">
                <dt>Capacité</dt>
                <dd>{p.capacity}</dd>
              </div>
              <div class="row">
                <dt>Durée</dt>
                <dd>{p.duration}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  const catButtons = document.querySelectorAll<HTMLButtonElement>(".cat-card");
  const wrapper = document.getElementById("cards-wrapper") as HTMLElement | null;
  const title = document.getElementById("cards-title") as HTMLElement | null;
  const closeBtn = document.getElementById("cards-close") as HTMLButtonElement | null;
  const cards = document.querySelectorAll<HTMLElement>(".card");

  function applyFilter(cat: string, label: string) {
    if (!wrapper || !title) return;
    wrapper.hidden = false;
    title.textContent = label;

    cards.forEach((card) => {
      const cats = (card.dataset.cats ?? "").split(",");
      const show = cat === "all" || cats.includes(cat);
      card.style.display = show ? "" : "none";
    });

    catButtons.forEach((b) => {
      const active = b.dataset.cat === cat;
      b.classList.toggle("active", active);
      b.setAttribute("aria-selected", String(active));
    });

    wrapper.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  catButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const cat = btn.dataset.cat ?? "all";
      const label = btn.querySelector(".cat-label")?.textContent ?? "Projets";
      applyFilter(cat, label);
    });
  });

  closeBtn?.addEventListener("click", () => {
    if (!wrapper) return;
    wrapper.hidden = true;
    catButtons.forEach((b) => {
      b.classList.remove("active");
      b.setAttribute("aria-selected", "false");
    });
  });
</script>

<style>
  .invest-page {
    padding: 1rem 0 3rem;
  }

  /* ── Category cards ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--gray);
    border-radius: 10px;
    background: var(--moretransblack);
    color: var(--text-color);
    cursor: pointer;
    font: inherit;
    text-align: left;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .cat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    border-color: var(--text-color);
  }
  .cat-card.active {
    border-color: var(--text-color);
    border-width: 2px;
    padding: calc(0.9rem - 1px) calc(1rem - 1px);
    background: var(--moretranswhite);
  }
  .cat-icon {
    font-size: 1.4rem;
    line-height: 1;
  }
  .cat-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-color);
  }
  .cat-count {
    font-size: 0.72rem;
    color: var(--gray);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }

  /* ── Cards wrapper ── */
  .cards-wrapper {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--gray);
  }
  .cards-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .cards-title {
    margin: 0;
    font-size: 1.1rem;
    color: var(--text-color);
  }
  .cards-close {
    background: none;
    border: none;
    color: var(--gray);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
  }
  .cards-close:hover {
    color: var(--text-color);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .card {
    border: 1px solid var(--gray);
    border-radius: 10px;
    padding: 1rem 1.1rem;
    background: var(--moretranswhite);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  }

  .card-head {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }
  .card-icon {
    font-size: 1.4rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .card-head-text {
    flex: 1;
    min-width: 0;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--text-color);
    line-height: 1.25;
  }
  .card-platform {
    display: inline-block;
    font-size: 0.7rem;
    color: var(--gray);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-top: 2px;
  }
  .card-year {
    font-size: 0.75rem;
    color: var(--gray);
    background: var(--moretransblack);
    padding: 2px 8px;
    border-radius: 999px;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .card-body {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.5rem;
    font-size: 0.82rem;
    line-height: 1.35;
  }
  .row dt {
    color: var(--gray);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    align-self: center;
  }
  .row dd {
    margin: 0;
    color: var(--text-color);
    word-break: break-word;
  }

  @media (prefers-color-scheme: dark) {
    .cat-card,
    .card,
    .card-year {
      background: var(--moretranswhite);
    }
    .cat-card.active {
      background: var(--moretransblack);
    }
  }

  @media (max-width: 600px) {
    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cards {
      grid-template-columns: 1fr;
    }
    .row {
      grid-template-columns: 5rem 1fr;
    }
  }
</style>
