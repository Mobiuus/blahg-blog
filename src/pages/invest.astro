---
import Layout from "../components/Layout.astro";
import { SITE_TITLE } from "../config";

type Category = "solaire" | "agrivoltaique" | "eolien" | "chaleur" | "stockage" | "autres";

interface Invest {
  developer: string;
  platform: string;
  location: string;
  type: string;
  year: number;
  date: string;
  duration: string;
  capacity: string;
  mwc: number | null;
  categories: Category[];
  coords: [number, number]; // [lat, lng]
}

const invests: Invest[] = [
  { developer: "Urba 308", platform: "Lendopolis", location: "Rolampont, Haute-Marne (52)", type: "Solaire PV au sol", year: 2025, date: "04/04/2025", duration: "48 mois", capacity: "5,0 MWc", mwc: 5.0, categories: ["solaire"], coords: [47.87, 5.23] },
  { developer: "GDSOL 98", platform: "Lendopolis", location: "Doulaincourt-Saucourt, Haute-Marne (52)", type: "Solaire PV au sol", year: 2025, date: "04/04/2025", duration: "42 mois", capacity: "5,7 MWc", mwc: 5.7, categories: ["solaire"], coords: [48.33, 5.23] },
  { developer: "TSE Développement", platform: "Enerfip", location: "Multi-régions, France", type: "Solaire PV au sol (portefeuille)", year: 2025, date: "09/05/2025", duration: "42 mois", capacity: "199,8 MWc", mwc: 199.8, categories: ["solaire"], coords: [46.60, 2.50] },
  { developer: "Montbéliard Énergies", platform: "Enerfip", location: "Montbéliard, Doubs (25)", type: "Réseau de chaleur (bois-énergie)", year: 2025, date: "21/05/2025", duration: "36 mois", capacity: "N/A", mwc: null, categories: ["chaleur"], coords: [47.51, 6.80] },
  { developer: "Solskin 10 (Barconnière)", platform: "Enerfip", location: "Multi-dépts (16, 86, 87, 33, 79)", type: "Solaire PV toiture / hangars agricoles", year: 2025, date: "27/10/2025", duration: "24 mois", capacity: "2,6 MWc", mwc: 2.6, categories: ["solaire"], coords: [45.70, 0.80] },
  { developer: "Eco Chaleur du Mantois", platform: "Lendosphère", location: "Mantes-la-Jolie, Yvelines (78)", type: "Réseau de chaleur (extension)", year: 2025, date: "25/11/2025", duration: "36 mois", capacity: "N/A", mwc: null, categories: ["chaleur"], coords: [48.99, 1.72] },
  { developer: "Centrale PV de Cosne-sur-Loire", platform: "Lendosphère", location: "Cosne-sur-Loire, Nièvre (58)", type: "Solaire PV au sol", year: 2025, date: "25/11/2025", duration: "42 mois", capacity: "N/A (2 centrales)", mwc: null, categories: ["solaire"], coords: [47.41, 2.92] },
  { developer: "Agri Italia Power (Energreen)", platform: "Enerfip", location: "Vallermosa & Samassi, Sardaigne (IT)", type: "Agrivoltaïque", year: 2026, date: "03/01/2026", duration: "24 mois", capacity: "3,0 MWc", mwc: 3.0, categories: ["agrivoltaique", "solaire"], coords: [39.46, 8.85] },
  { developer: "Combes de la Romaine (Neoen)", platform: "Lendosphère", location: "Haute-Saône (70)", type: "Éolien terrestre (développement)", year: 2026, date: "22/02/2026", duration: "24 mois", capacity: "N/A", mwc: null, categories: ["eolien"], coords: [47.62, 6.15] },
  { developer: "LORIS ENR CEE T2", platform: "Enerfip", location: "France (national)", type: "CEE / BFR (non-production)", year: 2026, date: "03/03/2026", duration: "36 mois", capacity: "N/A", mwc: null, categories: ["autres"], coords: [46.60, 2.50] },
  { developer: "Campania Solar T2 (SIG)", platform: "Enerfip", location: "Campanie, Italie", type: "Solaire PV au sol (portefeuille)", year: 2026, date: "07/03/2026", duration: "24 mois", capacity: "137,9 MWc", mwc: 137.9, categories: ["solaire"], coords: [40.84, 14.25] },
  { developer: "Solar Reserve T2 (NRG Plus Italia)", platform: "Enerfip", location: "Lombardie, Émilie-Romagne, Pouilles (IT)", type: "PV agrivoltaïque + BESS stockage", year: 2026, date: "07/03/2026", duration: "36 mois", capacity: "~472 MWc", mwc: 472, categories: ["agrivoltaique", "solaire", "stockage"], coords: [43.00, 12.50] },
  { developer: "Torrente Solar (Kenergy)", platform: "Lendosphère", location: "Communauté Valencienne, Espagne", type: "Solaire PV au sol (4 centrales)", year: 2026, date: "15/03/2026", duration: "36 mois", capacity: "~205 MWc", mwc: 205, categories: ["solaire"], coords: [39.47, -0.38] },
  { developer: "Mâcon La Grisière (SMEG)", platform: "Lendosphère", location: "Mâcon, Saône-et-Loire (71)", type: "Solaire PV au sol", year: 2026, date: "18/04/2026", duration: "36 mois", capacity: "5,93 MWc", mwc: 5.93, categories: ["solaire"], coords: [46.31, 4.83] },
];

const sorted = [...invests].sort((a, b) => {
  const [da, ma, ya] = a.date.split("/").map(Number);
  const [db, mb, yb] = b.date.split("/").map(Number);
  return new Date(yb, mb - 1, db).getTime() - new Date(ya, ma - 1, da).getTime();
});

interface Cat {
  key: "all" | Category;
  label: string;
  color: string;
}

const categories: Cat[] = [
  { key: "all",           label: "Total",             color: "#6b6b6b" },
  { key: "solaire",       label: "Solaire",           color: "#e9bc3f" },
  { key: "agrivoltaique", label: "Agrivoltaïque",     color: "#24d05a" },
  { key: "eolien",        label: "Éolien",            color: "#10a2f5" },
  { key: "chaleur",       label: "Réseau de chaleur", color: "#e48500" },
  { key: "stockage",      label: "Stockage (BESS)",   color: "#eb4888" },
  { key: "autres",        label: "Autres",            color: "#a4a4a4" },
];

function statsFor(key: Cat["key"]): { count: number; mwc: number } {
  const filtered = key === "all"
    ? invests
    : invests.filter((i) => i.categories.includes(key as Category));
  const mwc = filtered.reduce((acc, i) => acc + (i.mwc ?? 0), 0);
  return { count: filtered.length, mwc };
}

function fmtMwc(v: number): string {
  if (v === 0) return "—";
  return v.toFixed(1).replace(".", ",") + " MWc";
}

function iconFor(type: string): string {
  const t = type.toLowerCase();
  if (t.includes("éolien")) return "🌬️";
  if (t.includes("chaleur")) return "🔥";
  if (t.includes("bess") || t.includes("stockage")) return "🔋";
  if (t.includes("agrivolt")) return "🌾";
  if (t.includes("cee") || t.includes("bfr")) return "📄";
  if (t.includes("solaire") || t.includes("pv")) return "☀️";
  return "⚡";
}

const rows = categories.filter((c) => statsFor(c.key).count > 0);
---

<Layout title={`Invest | ${SITE_TITLE}`} description="Mes investissements dans les énergies renouvelables">
  <div class="invest-page">
    <!-- ── Carte géographique ── -->
    <div id="map" class="map" aria-label="Carte des projets"></div>

    <!-- ── Tableau récap ── -->
    <table class="recap">
      <thead>
        <tr>
          <th scope="col">Catégorie</th>
          <th scope="col" class="num">Projets</th>
          <th scope="col" class="num">Capacité</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((c) => {
          const s = statsFor(c.key);
          return (
            <tr
              class:list={["recap-row", { "recap-total": c.key === "all" }]}
              data-cat={c.key}
              tabindex="0"
              role="button"
              aria-label={`Filtrer: ${c.label}`}
            >
              <td>
                <span class="dot" style={`background:${c.color}`} aria-hidden="true"></span>
                {c.label}
              </td>
              <td class="num">{s.count}</td>
              <td class="num">{fmtMwc(s.mwc)}</td>
            </tr>
          );
        })}
      </tbody>
    </table>

    <!-- ── Liste filtrée (cachée par défaut) ── -->
    <div class="cards-wrapper" id="cards-wrapper" hidden>
      <div class="cards-head">
        <h2 class="cards-title" id="cards-title">Projets</h2>
        <button type="button" class="cards-close" id="cards-close" aria-label="Fermer">×</button>
      </div>
      <div class="cards" id="cards">
        {sorted.map((p) => (
          <article class="card" data-cats={p.categories.join(",")}>
            <header class="card-head">
              <span class="card-icon" aria-hidden="true">{iconFor(p.type)}</span>
              <div class="card-head-text">
                <h3 class="card-title">{p.developer}</h3>
                <span class="card-platform">{p.platform}</span>
              </div>
              <span class="card-year">{p.year}</span>
            </header>
            <dl class="card-body">
              <div class="row"><dt>Lieu</dt><dd>{p.location}</dd></div>
              <div class="row"><dt>Type</dt><dd>{p.type}</dd></div>
              <div class="row"><dt>Capacité</dt><dd>{p.capacity}</dd></div>
              <div class="row"><dt>Durée</dt><dd>{p.duration}</dd></div>
            </dl>
          </article>
        ))}
      </div>
    </div>
  </div>
</Layout>

<!-- ── Leaflet (OpenStreetMap) via CDN ── -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  // @ts-nocheck
  const CAT_COLORS: Record<string, string> = {
    solaire: "#e9bc3f",
    agrivoltaique: "#24d05a",
    eolien: "#10a2f5",
    chaleur: "#e48500",
    stockage: "#eb4888",
    autres: "#a4a4a4",
  };

  interface ProjectMeta {
    developer: string;
    location: string;
    type: string;
    capacity: string;
    year: number;
    categories: string[];
    coords: [number, number];
  }

  const projects: ProjectMeta[] = JSON.parse(
    document.getElementById("projects-data")?.textContent ?? "[]"
  );

  const rows = document.querySelectorAll<HTMLTableRowElement>(".recap-row");
  const wrapper = document.getElementById("cards-wrapper") as HTMLElement | null;
  const title = document.getElementById("cards-title") as HTMLElement | null;
  const closeBtn = document.getElementById("cards-close") as HTMLButtonElement | null;
  const cards = document.querySelectorAll<HTMLElement>(".card");

  let map: any = null;
  let markers: any[] = [];

  async function initMap() {
    // Dynamic import of Leaflet JS
    await new Promise<void>((resolve, reject) => {
      const s = document.createElement("script");
      s.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      s.integrity = "sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=";
      s.crossOrigin = "";
      s.onload = () => resolve();
      s.onerror = () => reject(new Error("leaflet load failed"));
      document.head.appendChild(s);
    });

    const L = (window as any).L;
    const el = document.getElementById("map");
    if (!el || !L) return;

    map = L.map(el, { scrollWheelZoom: false }).setView([45.5, 5.0], 4);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "© OpenStreetMap",
      maxZoom: 18,
    }).addTo(map);

    projects.forEach((p) => {
      const primary = p.categories[0] ?? "autres";
      const color = CAT_COLORS[primary] ?? "#6b6b6b";
      const m = L.circleMarker(p.coords, {
        radius: 8,
        color: "#fff",
        weight: 2,
        fillColor: color,
        fillOpacity: 0.9,
      })
        .bindPopup(
          `<strong>${p.developer}</strong><br>
           <small>${p.location}</small><br>
           ${p.type}<br>
           <em>${p.capacity} · ${p.year}</em>`
        )
        .addTo(map);
      (m as any)._cats = p.categories;
      markers.push(m);
    });

    // Fix sizing after mount
    setTimeout(() => map.invalidateSize(), 50);
  }

  function filterMarkers(cat: string) {
    if (!map) return;
    const L = (window as any).L;
    markers.forEach((m) => {
      const cats: string[] = (m as any)._cats ?? [];
      const show = cat === "all" || cats.includes(cat);
      if (show) m.addTo(map);
      else map.removeLayer(m);
    });
  }

  function applyFilter(cat: string, label: string) {
    if (!wrapper || !title) return;
    wrapper.hidden = false;
    title.textContent = label;

    cards.forEach((card) => {
      const cats = (card.dataset.cats ?? "").split(",");
      const show = cat === "all" || cats.includes(cat);
      (card as HTMLElement).style.display = show ? "" : "none";
    });

    rows.forEach((r) => {
      const active = r.dataset.cat === cat;
      r.classList.toggle("active", active);
    });

    filterMarkers(cat);
  }

  rows.forEach((row) => {
    const trigger = () => {
      const cat = row.dataset.cat ?? "all";
      const label = row.querySelector("td")?.textContent?.trim() ?? "Projets";
      applyFilter(cat, label);
    };
    row.addEventListener("click", trigger);
    row.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        trigger();
      }
    });
  });

  closeBtn?.addEventListener("click", () => {
    if (!wrapper) return;
    wrapper.hidden = true;
    rows.forEach((r) => r.classList.remove("active"));
    filterMarkers("all");
  });

  initMap();
</script>

<!-- Project data for client-side script -->
<script type="application/json" id="projects-data" set:html={JSON.stringify(
  invests.map(({ developer, location, type, capacity, year, categories, coords }) => ({
    developer, location, type, capacity, year, categories, coords,
  }))
)}></script>

<style>
  .invest-page {
    padding: 1rem 0 3rem;
  }

  /* ── Map ── */
  .map {
    width: 100%;
    height: 380px;
    border-radius: 10px;
    border: 1px solid var(--gray);
    margin-bottom: 1.5rem;
    z-index: 0;
  }

  /* ── Table ── */
  .recap {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .recap th,
  .recap td {
    padding: 0.6rem 0.8rem;
    text-align: left;
    border-bottom: 1px solid var(--gray);
  }
  .recap th {
    color: var(--gray);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .recap td.num,
  .recap th.num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .recap-row {
    cursor: pointer;
    transition: background 0.12s ease;
  }
  .recap-row:hover {
    background: var(--moretransblack);
  }
  .recap-row.active {
    background: var(--moretransblack);
    font-weight: 600;
  }
  .recap-row.recap-total td {
    font-weight: 700;
    color: var(--text-color);
    border-bottom: 2px solid var(--text-color);
  }
  .dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-right: 0.6rem;
    vertical-align: middle;
  }

  /* ── Cards wrapper ── */
  .cards-wrapper {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--gray);
  }
  .cards-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .cards-title {
    margin: 0;
    font-size: 1.1rem;
    color: var(--text-color);
  }
  .cards-close {
    background: none;
    border: none;
    color: var(--gray);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
  }
  .cards-close:hover {
    color: var(--text-color);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .card {
    border: 1px solid var(--gray);
    border-radius: 10px;
    padding: 1rem 1.1rem;
    background: var(--moretranswhite);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  }
  .card-head {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }
  .card-icon {
    font-size: 1.4rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .card-head-text {
    flex: 1;
    min-width: 0;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--text-color);
    line-height: 1.25;
  }
  .card-platform {
    display: inline-block;
    font-size: 0.7rem;
    color: var(--gray);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-top: 2px;
  }
  .card-year {
    font-size: 0.75rem;
    color: var(--gray);
    background: var(--moretransblack);
    padding: 2px 8px;
    border-radius: 999px;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .card-body {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.5rem;
    font-size: 0.82rem;
    line-height: 1.35;
  }
  .row dt {
    color: var(--gray);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    align-self: center;
  }
  .row dd {
    margin: 0;
    color: var(--text-color);
    word-break: break-word;
  }

  @media (prefers-color-scheme: dark) {
    .card,
    .card-year {
      background: var(--moretranswhite);
    }
    .recap-row:hover,
    .recap-row.active {
      background: var(--moretranswhite);
    }
  }

  @media (max-width: 600px) {
    .map {
      height: 300px;
    }
    .cards {
      grid-template-columns: 1fr;
    }
    .row {
      grid-template-columns: 5rem 1fr;
    }
    .recap {
      font-size: 0.85rem;
    }
    .recap th,
    .recap td {
      padding: 0.5rem 0.4rem;
    }
  }
</style>
